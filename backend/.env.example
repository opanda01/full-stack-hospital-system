DATABASE_URL=postgresql+psycopg://hastane:hastane@localhost:5432/hastane_db
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

OTP_TTL_SECONDS=300
OTP_MAX_DENEME=5
OTP_RATE_LIMIT_DAKIKA=1
OTP_GUNLUK_MAX=5

BILDIRIM_BACKEND=console
TEMP_SIFRE_UZUNLUK=12

# SMTP (BILDIRIM_BACKEND=smtp iken)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Virgülle ayrılmış; boş bırakılırsa X-Forwarded-For yok sayılır
TRUSTED_PROXY_IPS=

# CORS: virgülle ayrılmış origin; * = geliştirme
CORS_ORIGINS=*

# Dakikada IP başına login; 0 = kapalı
LOGIN_RATE_LIMIT_PER_MINUTE=20

# Denetim listesi / saklama (gün); 0 = sınırsız
AUDIT_RETENTION_DAYS=365

# SQLAlchemy pool (prod: pool_size × workers < max_connections)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

# Redis cache (boş = CELERY_BROKER host, db /2)
REDIS_CACHE_URL=

AUTH_REGISTER_SUNSET=Sat, 01 Jan 2027 00:00:00 GMT
